NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Oracle DB (Updated for ShopSphere)
DB_USER=shopsphere
DB_PASSWORD=Shop1234
DB_CONNECT_STRING=localhost:1521/xe

# Razorpay (Get these from Settings > API Keys in Razorpay Dashboard)
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=your_key_secret

# Brevo Email (SMTP Key from Brevo > Settings)
FROM_EMAIL=hello@shopsphere.com
BREVO_API_KEY=your_brevo_smtp_key

# Cloudinary (From Cloudinary Dashboard)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# JWT (Use a long random string for security)
JWT_SECRET=shopsphere_secure_token_2026_niyati